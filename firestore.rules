rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'ashokpal76199@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Users ---
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn(); // Allow profile updates and cross-user referral rewards
    }

    // --- Tournaments ---
    match /tournaments/{tournamentId} {
      allow read: if true;
      allow write: if isAdmin();
      allow update: if isSignedIn(); // Allow updating registeredCount during registration
    }

    // --- Registrations ---
    match /registrations/{registrationId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    // --- Transactions ---
    match /transactions/{transactionId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn(); // Players create transactions for entry fees, referrals, etc.
      allow update, delete: if isAdmin();
    }

    // --- Payment Requests (Deposits) ---
    match /paymentRequests/{requestId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
    }

    // --- Withdrawal Requests ---
    match /withdrawalRequests/{requestId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
    }

    // --- Notifications ---
    match /notifications/{notificationId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn(); // Players can trigger notifications (e.g., to referrer)
      allow update, delete: if isAdmin();
    }

    // --- System ---
    match /system/news {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /system/config {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Redeem Codes ---
    match /redeemCodes/{codeId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
      allow update: if isSignedIn();
    }

    // --- Referrals ---
    match /referrals/{referralId} {
      allow read: if isSignedIn() && (resource.data.referrerId == request.auth.uid || resource.data.referredUserId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
  }
}
